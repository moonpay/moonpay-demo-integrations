# MoonPay Secret Key (private) — used for HMAC-SHA256 URL signing
# Get yours at https://dashboard.moonpay.com/developers
# NEVER expose this in frontend code
MOONPAY_SECRET_KEY=sk_test_your_secret_key_here

# Server port (optional, defaults to 5000)
PORT=5000

# Allowed CORS origins (comma-separated, defaults to localhost:3000,localhost:3001)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
